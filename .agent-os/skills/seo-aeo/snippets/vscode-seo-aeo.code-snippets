{
  "SEO Full Head Block": {
    "prefix": "seo-head",
    "body": [
      "<!-- PRIMARY META -->",
      "<meta charset=\"UTF-8\">",
      "<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">",
      "<title>${1:Primary Keyword} | ${2:Brand} — ${3:Value Prop}</title>",
      "<meta name=\"description\" content=\"${4:Description with keyword in first 20 words. Max 155 chars.}\">",
      "<meta name=\"robots\" content=\"index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1\">",
      "<link rel=\"canonical\" href=\"https://${5:domain}/${6:slug}/\">",
      "",
      "<!-- OPEN GRAPH -->",
      "<meta property=\"og:type\" content=\"${7|website,article,product,profile|}\">",
      "<meta property=\"og:title\" content=\"${1:Primary Keyword} | ${2:Brand}\">",
      "<meta property=\"og:description\" content=\"${4:Description}\">",
      "<meta property=\"og:image\" content=\"https://${5:domain}/og-image.jpg\">",
      "<meta property=\"og:image:width\" content=\"1200\">",
      "<meta property=\"og:image:height\" content=\"630\">",
      "<meta property=\"og:url\" content=\"https://${5:domain}/${6:slug}/\">",
      "<meta property=\"og:site_name\" content=\"${2:Brand}\">",
      "<meta property=\"og:locale\" content=\"en_IN\">",
      "",
      "<!-- TWITTER -->",
      "<meta name=\"twitter:card\" content=\"summary_large_image\">",
      "<meta name=\"twitter:title\" content=\"${1:Primary Keyword} | ${2:Brand}\">",
      "<meta name=\"twitter:description\" content=\"${4:Description}\">",
      "<meta name=\"twitter:image\" content=\"https://${5:domain}/twitter-card.jpg\">"
    ],
    "description": "Full SEO head block with OG and Twitter cards"
  },

  "Schema Organization": {
    "prefix": "schema-org",
    "body": [
      "<script type=\"application/ld+json\">",
      "{",
      "  \"@context\": \"https://schema.org\",",
      "  \"@type\": \"Organization\",",
      "  \"name\": \"${1:Business Name}\",",
      "  \"url\": \"https://${2:domain}\",",
      "  \"logo\": { \"@type\": \"ImageObject\", \"url\": \"https://${2:domain}/logo.png\" },",
      "  \"description\": \"${3:One sentence with primary keyword}\",",
      "  \"foundingDate\": \"${4:YYYY}\",",
      "  \"address\": {",
      "    \"@type\": \"PostalAddress\",",
      "    \"addressLocality\": \"${5:City}\",",
      "    \"addressRegion\": \"${6:State}\",",
      "    \"addressCountry\": \"IN\"",
      "  },",
      "  \"sameAs\": [\"${7:linkedin_url}\", \"${8:twitter_url}\"]",
      "}",
      "</script>"
    ],
    "description": "Organization schema markup"
  },

  "Schema FAQ": {
    "prefix": "schema-faq",
    "body": [
      "<script type=\"application/ld+json\">",
      "{",
      "  \"@context\": \"https://schema.org\",",
      "  \"@type\": \"FAQPage\",",
      "  \"mainEntity\": [",
      "    {",
      "      \"@type\": \"Question\",",
      "      \"name\": \"${1:Question one?}\",",
      "      \"acceptedAnswer\": { \"@type\": \"Answer\", \"text\": \"${2:Direct answer here.}\" }",
      "    },",
      "    {",
      "      \"@type\": \"Question\",",
      "      \"name\": \"${3:Question two?}\",",
      "      \"acceptedAnswer\": { \"@type\": \"Answer\", \"text\": \"${4:Direct answer here.}\" }",
      "    }",
      "  ]",
      "}",
      "</script>"
    ],
    "description": "FAQPage schema markup"
  },

  "Schema Article": {
    "prefix": "schema-article",
    "body": [
      "<script type=\"application/ld+json\">",
      "{",
      "  \"@context\": \"https://schema.org\",",
      "  \"@type\": \"Article\",",
      "  \"headline\": \"${1:Exact H1}\",",
      "  \"description\": \"${2:Meta description}\",",
      "  \"image\": [\"https://${3:domain}/image.jpg\"],",
      "  \"author\": { \"@type\": \"Person\", \"name\": \"${4:Author Name}\" },",
      "  \"publisher\": {",
      "    \"@type\": \"Organization\",",
      "    \"name\": \"${5:Brand}\",",
      "    \"logo\": { \"@type\": \"ImageObject\", \"url\": \"https://${3:domain}/logo.png\" }",
      "  },",
      "  \"datePublished\": \"${6:YYYY-MM-DD}\",",
      "  \"dateModified\": \"${7:YYYY-MM-DD}\",",
      "  \"mainEntityOfPage\": { \"@type\": \"WebPage\", \"@id\": \"https://${3:domain}/${8:slug}/\" }",
      "}",
      "</script>"
    ],
    "description": "Article schema markup"
  },

  "Schema Breadcrumb": {
    "prefix": "schema-breadcrumb",
    "body": [
      "<script type=\"application/ld+json\">",
      "{",
      "  \"@context\": \"https://schema.org\",",
      "  \"@type\": \"BreadcrumbList\",",
      "  \"itemListElement\": [",
      "    { \"@type\": \"ListItem\", \"position\": 1, \"name\": \"Home\", \"item\": \"https://${1:domain}\" },",
      "    { \"@type\": \"ListItem\", \"position\": 2, \"name\": \"${2:Category}\", \"item\": \"https://${1:domain}/${3:category}/\" },",
      "    { \"@type\": \"ListItem\", \"position\": 3, \"name\": \"${4:Page}\", \"item\": \"https://${1:domain}/${3:category}/${5:slug}/\" }",
      "  ]",
      "}",
      "</script>"
    ],
    "description": "BreadcrumbList schema markup"
  },

  "Schema Local Business": {
    "prefix": "schema-local",
    "body": [
      "<script type=\"application/ld+json\">",
      "{",
      "  \"@context\": \"https://schema.org\",",
      "  \"@type\": \"LocalBusiness\",",
      "  \"name\": \"${1:Business Name}\",",
      "  \"@id\": \"https://${2:domain}/#localbusiness\",",
      "  \"url\": \"https://${2:domain}\",",
      "  \"telephone\": \"+91-${3:XXXXXXXXXX}\",",
      "  \"address\": {",
      "    \"@type\": \"PostalAddress\",",
      "    \"streetAddress\": \"${4:Street}\",",
      "    \"addressLocality\": \"${5:City}\",",
      "    \"addressRegion\": \"${6:State}\",",
      "    \"postalCode\": \"${7:PIN}\",",
      "    \"addressCountry\": \"IN\"",
      "  },",
      "  \"geo\": { \"@type\": \"GeoCoordinates\", \"latitude\": ${8:0.0}, \"longitude\": ${9:0.0} }",
      "}",
      "</script>"
    ],
    "description": "LocalBusiness schema markup"
  },

  "Robots.txt Base": {
    "prefix": "robots-base",
    "body": [
      "User-agent: *",
      "Disallow: /admin/",
      "Disallow: /login/",
      "Disallow: /checkout/",
      "Disallow: /wp-admin/",
      "Allow: /wp-admin/admin-ajax.php",
      "",
      "User-agent: GPTBot",
      "Allow: /",
      "",
      "User-agent: Google-Extended",
      "Allow: /",
      "",
      "User-agent: PerplexityBot",
      "Allow: /",
      "",
      "Sitemap: https://${1:domain}/sitemap_index.xml"
    ],
    "description": "Base robots.txt with AI crawler permissions"
  },

  "AEO Answer Block": {
    "prefix": "aeo-answer",
    "body": [
      "<div class=\"answer-block\">",
      "  <h3>What is ${1:Topic}?</h3>",
      "  <p>${1:Topic} is ${2:direct one-sentence definition}. It works by ${3:mechanism}. Primary benefit: ${4:value}. Used for: ${5:use cases}.</p>",
      "</div>"
    ],
    "description": "AEO direct answer block for AI engine citation"
  },

  "IndexNow Submit": {
    "prefix": "indexnow",
    "body": [
      "const submitIndexNow = async (urls) => {",
      "  const response = await fetch('https://api.indexnow.org/indexnow', {",
      "    method: 'POST',",
      "    headers: { 'Content-Type': 'application/json' },",
      "    body: JSON.stringify({",
      "      host: '${1:domain}',",
      "      key: '${2:YOUR_INDEXNOW_KEY}',",
      "      keyLocation: 'https://${1:domain}/${2:YOUR_INDEXNOW_KEY}.txt',",
      "      urlList: urls",
      "    })",
      "  });",
      "  return response.status;",
      "};"
    ],
    "description": "IndexNow API function for instant Bing/Yandex indexing"
  }
}
